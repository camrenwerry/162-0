{
  "name": "pennant-pursuit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "data:build": "node scripts/build-player-pools.mjs",
    "data:audit": "node scripts/audit-player-stats.mjs",
    "data:report": "node scripts/report-player-pools.mjs",
    "data:validate": "node scripts/validate-player-pools.mjs",
    "data:lahman:build": "node scripts/build-lahman-data.mjs",
    "data:lahman:validate": "node scripts/validate-lahman-data.mjs",
    "data:lahman:report": "node scripts/report-lahman-data.mjs",
    "data:worker:build": "node scripts/build-worker-catalog.mjs",
    "fixtures:server-validation:build": "vite build --ssr scripts/build-server-validation-fixtures.ts --outDir /tmp/pennant-pursuit-server-fixtures --emptyOutDir && node /tmp/pennant-pursuit-server-fixtures/build-server-validation-fixtures.js",
    "audit:historical": "node scripts/audit-historical-data.mjs",
    "audit:stars": "node scripts/audit-historical-data.mjs --section=star",
    "audit:positions": "node scripts/audit-historical-data.mjs --section=position",
    "audit:seasons": "node scripts/audit-historical-data.mjs --section=season",
    "data:lahman:all": "npm run data:lahman:build && npm run data:lahman:validate && npm run data:lahman:report",
    "brand:assets": "node scripts/build-brand-assets.mjs && pwa-assets-generator",
    "pwa:icons": "pwa-assets-generator",
    "dev": "vite",
    "dev:pages": "npm run build && wrangler pages dev --persist-to .wrangler/state",
    "build": "npm run validate:data && tsc -b && vite build",
    "functions:types": "wrangler types ./functions/types.d.ts",
    "functions:types:check": "wrangler types ./functions/types.d.ts --check",
    "functions:typecheck": "tsc --project functions/tsconfig.json --noEmit",
    "db:migrations:list:local": "wrangler d1 migrations list pennant-pursuit-preview --local --persist-to .wrangler/state --env=\"\"",
    "db:migrations:apply:local": "wrangler d1 migrations apply pennant-pursuit-preview --local --persist-to .wrangler/state --env=\"\"",
    "db:migrations:list:preview": "wrangler d1 migrations list pennant-pursuit-preview --remote --env=\"\"",
    "db:migrations:apply:preview": "wrangler d1 migrations apply pennant-pursuit-preview --remote --env=\"\"",
    "db:migrations:list:production": "wrangler d1 migrations list pennant-pursuit-production --remote --env production",
    "db:migrations:apply:production": "node scripts/apply-production-migrations.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:data": "node scripts/lahman-pipeline.test.mjs",
    "test:data:legacy": "node scripts/player-pipeline.test.mjs",
    "test:engine": "vite build --ssr scripts/engine-smoke.ts --outDir /tmp/pennant-pursuit-engine-smoke --emptyOutDir && node /tmp/pennant-pursuit-engine-smoke/engine-smoke.js",
    "test:game": "node scripts/smoke-game.mjs",
    "test:navigation": "node scripts/navigation-smoke.test.mjs",
    "test:scoring": "vite build --ssr scripts/scoring.test.ts --outDir /tmp/pennant-pursuit-scoring-tests --emptyOutDir && node /tmp/pennant-pursuit-scoring-tests/scoring.test.js",
    "test:rng": "vite build --ssr scripts/seeded-random.test.ts --outDir /tmp/pennant-pursuit-seeded-rng-tests --emptyOutDir && node /tmp/pennant-pursuit-seeded-rng-tests/seeded-random.test.js",
    "test:replay": "vite build --ssr scripts/transcript-replay.test.ts --outDir /tmp/pennant-pursuit-transcript-replay-tests --emptyOutDir && node /tmp/pennant-pursuit-transcript-replay-tests/transcript-replay.test.js",
    "test:server-validation": "vite build --ssr scripts/server-validation.test.ts --outDir /tmp/pennant-pursuit-server-validation-tests --emptyOutDir && node /tmp/pennant-pursuit-server-validation-tests/server-validation.test.js",
    "test:draft-validation": "vite build --ssr scripts/draft-validation-route.test.ts --outDir /tmp/pennant-pursuit-draft-validation-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-tests/draft-validation-route.test.js",
    "benchmark:draft-validation": "vite build --ssr scripts/draft-validation-benchmark.ts --outDir /tmp/pennant-pursuit-draft-validation-benchmark --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-benchmark/draft-validation-benchmark.js",
    "benchmark:server-validation": "vite build --ssr scripts/server-validation-worker-entry.ts --outDir /tmp/pennant-pursuit-server-validation-worker --emptyOutDir && vite build --ssr scripts/server-validation-benchmark.ts --outDir /tmp/pennant-pursuit-server-validation-benchmark --emptyOutDir && node /tmp/pennant-pursuit-server-validation-benchmark/server-validation-benchmark.js",
    "test:randomizer": "vite build --ssr scripts/randomizer.test.ts --outDir /tmp/pennant-pursuit-randomizer-tests --emptyOutDir && node /tmp/pennant-pursuit-randomizer-tests/randomizer.test.js",
    "test:randomizer-distribution": "vite build --ssr scripts/randomizer-distribution.ts --outDir /tmp/pennant-pursuit-randomizer-distribution --emptyOutDir && node /tmp/pennant-pursuit-randomizer-distribution/randomizer-distribution.js",
    "scoring:benchmarks": "vite build --ssr scripts/scoring-benchmarks.ts --outDir /tmp/pennant-pursuit-scoring-benchmarks --emptyOutDir && node /tmp/pennant-pursuit-scoring-benchmarks/scoring-benchmarks.js",
    "scoring:distribution": "vite build --ssr scripts/scoring-distribution.ts --outDir /tmp/pennant-pursuit-scoring-distribution --emptyOutDir && node /tmp/pennant-pursuit-scoring-distribution/scoring-distribution.js",
    "test:responsive": "node scripts/responsive-contract.test.mjs",
    "test:presentation": "node scripts/v010-presentation.test.mjs",
    "test:backend": "npm run build && vite build --ssr scripts/backend-foundation.test.ts --outDir /tmp/pennant-pursuit-backend-tests --emptyOutDir && node /tmp/pennant-pursuit-backend-tests/backend-foundation.test.js",
    "test:production-migration": "node scripts/production-migration-guard.test.mjs",
    "test:release": "vite build --ssr scripts/release-readiness.test.ts --outDir /tmp/pennant-pursuit-release-tests --emptyOutDir && node /tmp/pennant-pursuit-release-tests/release-readiness.test.js",
    "test:pwa": "node scripts/pwa-deployment.test.mjs",
    "validate:data": "npm run data:lahman:validate"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "4.111.0"
  }
}
