{
  "name": "pennant-pursuit",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "data:build": "node scripts/build-player-pools.mjs",
    "data:audit": "node scripts/audit-player-stats.mjs",
    "data:report": "node scripts/report-player-pools.mjs",
    "data:validate": "node scripts/validate-player-pools.mjs",
    "data:lahman:build": "node scripts/build-lahman-data.mjs",
    "data:lahman:validate": "node scripts/validate-lahman-data.mjs",
    "data:lahman:report": "node scripts/report-lahman-data.mjs",
    "data:worker:build": "node scripts/build-worker-catalog.mjs",
    "fixtures:server-validation:build": "vite build --ssr scripts/build-server-validation-fixtures.ts --outDir /tmp/pennant-pursuit-server-fixtures --emptyOutDir && node /tmp/pennant-pursuit-server-fixtures/build-server-validation-fixtures.js",
    "audit:historical": "node scripts/audit-historical-data.mjs",
    "audit:stars": "node scripts/audit-historical-data.mjs --section=star",
    "audit:positions": "node scripts/audit-historical-data.mjs --section=position",
    "audit:seasons": "node scripts/audit-historical-data.mjs --section=season",
    "data:lahman:all": "npm run data:lahman:build && npm run data:lahman:validate && npm run data:lahman:report",
    "brand:assets": "node scripts/build-brand-assets.mjs && pwa-assets-generator",
    "pwa:icons": "pwa-assets-generator",
    "dev": "vite",
    "dev:pages": "npm run build && wrangler pages dev --persist-to .wrangler/state",
    "dev:validation-worker": "wrangler --cwd workers/draft-validation dev",
    "dev:pages-with-validation": "npm run build && wrangler pages dev --persist-to .wrangler/state --service VALIDATION_SERVICE=pennant-pursuit-validation-preview",
    "build": "npm run validate:data && tsc -b && vite build",
    "app:typecheck": "tsc -b",
    "functions:types": "wrangler types ./functions/types.d.ts",
    "functions:types:check": "wrangler types ./functions/types.d.ts --check",
    "functions:typecheck": "tsc --project functions/tsconfig.json --noEmit",
    "validation-worker:types": "wrangler --cwd workers/draft-validation types ./worker-configuration.d.ts",
    "validation-worker:types:check": "wrangler --cwd workers/draft-validation types ./worker-configuration.d.ts --check",
    "validation-worker:typecheck": "tsc --project workers/draft-validation/tsconfig.json --noEmit",
    "validation-worker:build": "wrangler --cwd workers/draft-validation deploy --env=\"\" --dry-run --minify --outdir /tmp/pennant-pursuit-validation-worker-build",
    "validation-worker:production:build": "wrangler --cwd workers/draft-validation deploy --env production --dry-run --minify --outdir /tmp/pennant-pursuit-validation-production-worker-build",
    "pages:functions:build": "wrangler pages functions build functions --project-directory . --outdir /tmp/pennant-pursuit-pages-c4-build --minify --metafile",
    "validation-bundles:check": "node scripts/check-validation-bundles.mjs",
    "db:migrations:list:local": "wrangler d1 migrations list pennant-pursuit-preview --local --persist-to .wrangler/state --env=\"\"",
    "db:migrations:apply:local": "wrangler d1 migrations apply pennant-pursuit-preview --local --persist-to .wrangler/state --env=\"\"",
    "db:migrations:list:preview": "wrangler d1 migrations list pennant-pursuit-preview --remote --env=\"\"",
    "db:migrations:apply:preview": "wrangler d1 migrations apply pennant-pursuit-preview --remote --env=\"\"",
    "db:migrations:list:production": "wrangler d1 migrations list pennant-pursuit-production --remote --env production",
    "db:migrations:apply:production": "node scripts/apply-production-migrations.mjs",
    "d1c4:activation": "node scripts/prepare-d1c4-activation.mjs",
    "d1c4:activation:check": "node scripts/prepare-d1c4-activation.mjs --check",
    "d1c4:typecheck": "tsc --project scripts/tsconfig.d1c4.json --noEmit",
    "smoke:d1c4:submission": "vite build --ssr scripts/d1c4-submission-smoke.ts --outDir /tmp/pennant-pursuit-d1c4-submission-smoke --emptyOutDir && node /tmp/pennant-pursuit-d1c4-submission-smoke/d1c4-submission-smoke.js",
    "smoke:d1c4:retention": "vite build --ssr scripts/d1c4-retention-smoke.ts --outDir /tmp/pennant-pursuit-d1c4-retention-smoke --emptyOutDir && node /tmp/pennant-pursuit-d1c4-retention-smoke/d1c4-retention-smoke.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:data": "node scripts/lahman-pipeline.test.mjs",
    "test:data:legacy": "node scripts/player-pipeline.test.mjs",
    "test:engine": "vite build --ssr scripts/engine-smoke.ts --outDir /tmp/pennant-pursuit-engine-smoke --emptyOutDir && node /tmp/pennant-pursuit-engine-smoke/engine-smoke.js",
    "test:game": "node scripts/smoke-game.mjs",
    "test:navigation": "node scripts/navigation-smoke.test.mjs",
    "test:scoring": "vite build --ssr scripts/scoring.test.ts --outDir /tmp/pennant-pursuit-scoring-tests --emptyOutDir && node /tmp/pennant-pursuit-scoring-tests/scoring.test.js",
    "test:rng": "vite build --ssr scripts/seeded-random.test.ts --outDir /tmp/pennant-pursuit-seeded-rng-tests --emptyOutDir && node /tmp/pennant-pursuit-seeded-rng-tests/seeded-random.test.js",
    "test:replay": "vite build --ssr scripts/transcript-replay.test.ts --outDir /tmp/pennant-pursuit-transcript-replay-tests --emptyOutDir && node /tmp/pennant-pursuit-transcript-replay-tests/transcript-replay.test.js",
    "test:server-validation": "vite build --ssr scripts/server-validation.test.ts --outDir /tmp/pennant-pursuit-server-validation-tests --emptyOutDir && node /tmp/pennant-pursuit-server-validation-tests/server-validation.test.js",
    "test:draft-validation": "vite build --ssr scripts/draft-validation-route.test.ts --outDir /tmp/pennant-pursuit-draft-validation-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-tests/draft-validation-route.test.js",
    "test:draft-validation-hardening": "vite build --ssr scripts/draft-validation-hardening.test.ts --outDir /tmp/pennant-pursuit-draft-validation-hardening-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-hardening-tests/draft-validation-hardening.test.js",
    "test:draft-ticket": "vite build --ssr scripts/draft-ticket.test.ts --outDir /tmp/pennant-pursuit-draft-ticket-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-ticket-tests/draft-ticket.test.js",
    "test:draft-timing-safe-workerd": "vite build --ssr scripts/draft-timing-safe-workerd.worker.ts --outDir /tmp/pennant-pursuit-draft-timing-safe-workerd --emptyOutDir && node scripts/draft-timing-safe-workerd.test.mjs",
    "test:draft-validation-traffic-control": "vite build --ssr scripts/draft-validation-traffic-control.test.ts --outDir /tmp/pennant-pursuit-draft-validation-traffic-control-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-traffic-control-tests/draft-validation-traffic-control.test.js",
    "test:draft-submission": "vite build --ssr scripts/draft-submission.test.ts --outDir /tmp/pennant-pursuit-draft-submission-tests --emptyOutDir && node /tmp/pennant-pursuit-draft-submission-tests/draft-submission.test.js",
    "test:d1c3-retention-cleanup": "vite build --ssr scripts/d1c3-retention-cleanup.test.ts --outDir /tmp/pennant-pursuit-d1c3-retention-cleanup-tests --emptyOutDir && node /tmp/pennant-pursuit-d1c3-retention-cleanup-tests/d1c3-retention-cleanup.test.js",
    "test:d1c4-activation": "vite build --ssr scripts/d1c4-activation.test.ts --outDir /tmp/pennant-pursuit-d1c4-activation-tests --emptyOutDir && node /tmp/pennant-pursuit-d1c4-activation-tests/d1c4-activation.test.js",
    "test:d1c4-network-d1-client": "vite build --ssr scripts/d1c4-network-d1-client.test.ts --outDir /tmp/pennant-pursuit-d1c4-network-d1-client-tests --emptyOutDir && node /tmp/pennant-pursuit-d1c4-network-d1-client-tests/d1c4-network-d1-client.test.js",
    "test:d1c4-submission-cleanup": "vite build --ssr scripts/d1c4-submission-cleanup.test.ts --outDir /tmp/pennant-pursuit-d1c4-submission-cleanup-tests --emptyOutDir && node /tmp/pennant-pursuit-d1c4-submission-cleanup-tests/d1c4-submission-cleanup.test.js",
    "test:d1c4-smoke-harness": "vite build --ssr scripts/d1c4-smoke-harness.test.ts --outDir /tmp/pennant-pursuit-d1c4-smoke-harness-tests --emptyOutDir && node /tmp/pennant-pursuit-d1c4-smoke-harness-tests/d1c4-smoke-harness.test.js",
    "test:d1c4-corrections": "npm run test:d1c4-network-d1-client && npm run test:d1c4-submission-cleanup && npm run test:d1c4-smoke-harness",
    "test:validation-worker": "npm run test:draft-validation && npm run test:draft-validation-hardening && npm run test:draft-validation-traffic-control && npm run test:draft-submission && npm run test:d1c3-retention-cleanup && npm run test:d1c4-activation && npm run test:d1c4-corrections",
    "benchmark:draft-validation": "vite build --ssr scripts/draft-validation-benchmark.ts --outDir /tmp/pennant-pursuit-draft-validation-benchmark --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-benchmark/draft-validation-benchmark.js",
    "benchmark:draft-validation:startup": "vite build --ssr scripts/draft-validation-startup-benchmark.ts --outDir /tmp/pennant-pursuit-draft-validation-startup-benchmark --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-startup-benchmark/draft-validation-startup-benchmark.js",
    "benchmark:draft-validation-c4": "vite build --ssr scripts/draft-validation-c4-benchmark.ts --outDir /tmp/pennant-pursuit-draft-validation-c4-benchmark --emptyOutDir && node /tmp/pennant-pursuit-draft-validation-c4-benchmark/draft-validation-c4-benchmark.js",
    "benchmark:preview-draft-validation": "node scripts/preview-draft-validation-perf.mjs",
    "benchmark:server-validation": "vite build --ssr scripts/server-validation-worker-entry.ts --outDir /tmp/pennant-pursuit-server-validation-worker --emptyOutDir && vite build --ssr scripts/server-validation-benchmark.ts --outDir /tmp/pennant-pursuit-server-validation-benchmark --emptyOutDir && node /tmp/pennant-pursuit-server-validation-benchmark/server-validation-benchmark.js",
    "test:randomizer": "vite build --ssr scripts/randomizer.test.ts --outDir /tmp/pennant-pursuit-randomizer-tests --emptyOutDir && node /tmp/pennant-pursuit-randomizer-tests/randomizer.test.js",
    "test:randomizer-distribution": "vite build --ssr scripts/randomizer-distribution.ts --outDir /tmp/pennant-pursuit-randomizer-distribution --emptyOutDir && node /tmp/pennant-pursuit-randomizer-distribution/randomizer-distribution.js",
    "scoring:benchmarks": "vite build --ssr scripts/scoring-benchmarks.ts --outDir /tmp/pennant-pursuit-scoring-benchmarks --emptyOutDir && node /tmp/pennant-pursuit-scoring-benchmarks/scoring-benchmarks.js",
    "scoring:distribution": "vite build --ssr scripts/scoring-distribution.ts --outDir /tmp/pennant-pursuit-scoring-distribution --emptyOutDir && node /tmp/pennant-pursuit-scoring-distribution/scoring-distribution.js",
    "test:responsive": "node scripts/responsive-contract.test.mjs",
    "test:presentation": "node scripts/v010-presentation.test.mjs",
    "test:backend": "npm run build && vite build --ssr scripts/backend-foundation.test.ts --outDir /tmp/pennant-pursuit-backend-tests --emptyOutDir && node /tmp/pennant-pursuit-backend-tests/backend-foundation.test.js && npm run test:d1c1-foundation",
    "test:production-migration": "node scripts/production-migration-guard.test.mjs",
    "test:d1c1-foundation": "node scripts/d1c1-foundation.test.mjs",
    "test:release": "vite build --ssr scripts/release-readiness.test.ts --outDir /tmp/pennant-pursuit-release-tests --emptyOutDir && node /tmp/pennant-pursuit-release-tests/release-readiness.test.js",
    "test:pwa": "node scripts/pwa-deployment.test.mjs",
    "test:preview-check": "node scripts/preview-check.test.mjs",
    "test": "node scripts/preview-check.mjs --tests",
    "typecheck": "node scripts/preview-check.mjs --typecheck",
    "preview:check": "node scripts/preview-check.mjs",
    "validate:data": "npm run data:lahman:validate"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "4.111.0"
  }
}
