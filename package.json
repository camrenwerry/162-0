{
  "name": "diamond-draft",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "data:build": "node scripts/build-player-pools.mjs",
    "data:audit": "node scripts/audit-player-stats.mjs",
    "data:report": "node scripts/report-player-pools.mjs",
    "data:validate": "node scripts/validate-player-pools.mjs",
    "dev": "vite",
    "build": "npm run validate:data && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:data": "node scripts/player-pipeline.test.mjs",
    "test:engine": "vite build --ssr scripts/engine-smoke.ts --outDir /tmp/diamond-draft-engine-smoke --emptyOutDir && node /tmp/diamond-draft-engine-smoke/engine-smoke.js",
    "test:game": "node scripts/smoke-game.mjs",
    "test:scoring": "vite build --ssr scripts/scoring.test.ts --outDir /tmp/diamond-draft-scoring-tests --emptyOutDir && node /tmp/diamond-draft-scoring-tests/scoring.test.js",
    "validate:data": "npm run data:validate && npm run data:audit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
